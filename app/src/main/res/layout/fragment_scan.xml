<?xml version="1.0" encoding="utf-8"?>
<!-- DOSYA: app/src/main/res/layout/fragment_scan.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:padding="16dp">

    <!-- Başlık -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/apk_scanner"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <!-- Scanner Animasyon + Progress -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_dark"
        android:padding="20dp"
        android:gravity="center"
        android:layout_marginBottom="12dp">

        <!-- Scanner ikonu (dönen) -->
        <ImageView
            android:id="@+id/iv_scanner_icon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_scanner"
            android:layout_marginBottom="16dp"/>

        <!-- Durum metni -->
        <TextView
            android:id="@+id/tv_scan_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/scan_prompt"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/scan_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:progressTint="@color/neon_green"
            android:progressBackgroundTint="@color/bg_secondary"
            android:max="100"
            android:progress="0"
            android:layout_marginBottom="8dp"/>

        <!-- Progress metin -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_current_app"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="►"
                android:textColor="@color/neon_cyan"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:ellipsize="middle"
                android:singleLine="true"/>

            <TextView
                android:id="@+id/tv_progress_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/0"
                android:textColor="@color/text_dim"
                android:textSize="11sp"
                android:fontFamily="monospace"/>
        </LinearLayout>
    </LinearLayout>

    <!-- İstatistikler -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_card_dark"
            android:padding="12dp"
            android:gravity="center"
            android:layout_marginEnd="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/scanned"
                android:textColor="@color/text_dim"
                android:textSize="9sp"
                android:fontFamily="monospace"/>

            <TextView
                android:id="@+id/tv_scanned_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/neon_cyan"
                android:textSize="28sp"
                android:fontFamily="monospace"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_card_dark"
            android:padding="12dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/threat"
                android:textColor="@color/text_dim"
                android:textSize="9sp"
                android:fontFamily="monospace"/>

            <TextView
                android:id="@+id/tv_threat_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/neon_green"
                android:textSize="28sp"
                android:fontFamily="monospace"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- TARA Butonu -->
    <Button
        android:id="@+id/btn_start_scan"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/scan_system"
        android:textColor="@color/bg_primary"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:backgroundTint="@color/neon_green"
        android:layout_marginBottom="12dp"/>

    <!-- Bulunan Tehditler Listesi -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/found_threats"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"
        android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_threats"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
