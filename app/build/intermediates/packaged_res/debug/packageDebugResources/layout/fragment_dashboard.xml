<?xml version="1.0" encoding="utf-8"?>
<!-- DOSYA: app/src/main/res/layout/fragment_dashboard.xml -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Başlık -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/security_overview"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- Ana Güvenlik Kartı -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card_dark"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <!-- Hexagon -->
            <com.hydradragon.antivirus.views.HexagonStatusView
                android:id="@+id/hexagon_status"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginEnd="16dp"
                android:layout_gravity="center_vertical"/>

            <!-- Durum metni -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_security_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/system_is_safe"
                    android:textColor="@color/neon_green"
                    android:textSize="18sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_status_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/system_safe_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Canlı Ağ Grafiği -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_dark"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/live_network_activity"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tv_live_rate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0 evt/s"
                    android:textColor="@color/neon_cyan"
                    android:textSize="12sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <com.hydradragon.antivirus.views.LiveNetworkChart
                android:id="@+id/network_chart"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@color/bg_secondary"/>
        </LinearLayout>

        <!-- İstatistik Kartları -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Toplam Trafik -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card_dark"
                android:padding="12dp"
                android:gravity="center"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/total_traffic"
                    android:textColor="@color/text_dim"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tv_total_traffic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text_primary"
                    android:textSize="32sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Engellenen -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card_dark"
                android:padding="12dp"
                android:gravity="center"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/blocked"
                    android:textColor="@color/text_dim"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tv_blocked"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/threat_red"
                    android:textSize="32sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- İzin verilen -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card_dark"
                android:padding="12dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/allowed"
                    android:textColor="@color/text_dim"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tv_allowed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/neon_green"
                    android:textSize="32sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Gerçek Zamanlı Tehdit Akışı -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_dark"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/realtime_intelligence"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tv_engine_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/engine_active"
                    android:textColor="@color/neon_green"
                    android:textSize="10sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <!-- Tehdit akışı -->
            <TextView
                android:id="@+id/tv_threat_feed"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:background="@color/bg_secondary"
                android:padding="8dp"
                android:textColor="@color/neon_cyan"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:gravity="top"
                android:text="@string/system_waiting"
                android:scrollbars="vertical"
                android:overScrollMode="always"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
