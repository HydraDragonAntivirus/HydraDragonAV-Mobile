      6A 2B              // j+      push  0x2b
      58                 // X       pop   eax
      EB 0C              // ..      jmp   0x17
      69 C0 0F 01 00 00  // i.....  imul  eax, eax, 0x10f
      42                 // B       inc   edx
      0F B6 C9           // ...     movzx ecx, cl
      03 C1              // ..      add   eax, ecx
      8A 0A              // ..      mov   cl, byte ptr [edx]
      84 C9              // ..      test  cl, cl
      75 EE              // u.      jne   0xb
      5D                 // ]       pop   ebp
      C3                 // .       ret
    }

