    arch          = "x86, arm64"
    threat_name   = "Linux.Trojan.Pumakit"

  strings:
    $str1  = "PUMA %s"
    $str2  = "Kitsune PID %ld"
    $str3  = "/usr/share/zov_f"
    $str4  = "zarya"
    $str5  = ".puma-config"
    $str6  = "ping_interval_s"
    $str7  = "session_timeout_s"
    $str8  = "c2_timeout_s"
    $str9  = "LD_PRELOAD=/lib64/libs.so"
